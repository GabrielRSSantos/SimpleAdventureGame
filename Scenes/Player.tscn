[sub_resource type="GDScript" id="GDScript_lslt6"]
script/source = "extends CanvasLayer

@onready var world_1: VBoxContainer = $Menu/VBoxContainer/World1
@onready var world_2: VBoxContainer = $Menu/VBoxContainer/World2
@onready var world_3: VBoxContainer = $Menu/VBoxContainer/World3


func _ready() -> void:
	visible = false

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"E\"):
		hide_all_worlds()
		match PlayerManager.props[\"World\"][\"current_world\"]:
			1:
				world_1.visible = true
			2:
				world_2.visible = true
			3:
				world_3.visible = true
		toggle_pause()

func toggle_pause():
	var new_state = !get_tree().paused
	get_tree().paused = new_state
	visible = new_state
	
	if new_state:
		Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	else:
		Input.mouse_mode = Input.MOUSE_MODE_CAPTURED

func hide_all_worlds() -> void:
	world_1.visible = false
	world_2.visible = false
	world_2.visible = false
"

